<Window x:Class="WhisperWin.UI.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Whisper History" Height="560" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBox x:Name="SearchBox" Width="330" TextChanged="SearchBox_TextChanged" />
            <Button x:Name="ClearAllButton" Content="Clear All" Width="80" Margin="8,0,0,0" Click="ClearAllButton_Click" />
        </StackPanel>

        <TextBlock x:Name="EmptyStateText" DockPanel.Dock="Top"
                   Text="No history yet — dictate something!"
                   Foreground="Gray" HorizontalAlignment="Center" Margin="0,60,0,0"
                   Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EntriesList" />
        </ScrollViewer>
    </DockPanel>
</Window>
